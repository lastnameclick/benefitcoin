# Copy to .env and adjust as needed. The defaults match docker-compose.
ADDR=:8080
DATABASE_URL=postgres://cpal:cpal@localhost:5432/cpal?sslmode=disable
TB_ADDRESS=3000
TB_CLUSTER_ID=0

JWT_SECRET=dev-insecure-secret-change-me
ACCESS_TTL=15m
REFRESH_TTL=720h

# Households are created via self-serve signup (POST /api/v1/auth/signup);
# there is no seeded operator.

# Origin allowed to call the API from a browser (the Vite dev server).
CORS_ORIGIN=http://localhost:5173

# White-label branding — shown throughout the UI (display only; the internal
# ledger currency stays BNC). Change these to rebrand the whole product.
PRODUCT_NAME=BenefitCoins
SITE_NAME=BenefitCoins
COIN_NAME=coin
COIN_NAME_PLURAL=coins
COIN_CODE=BNC

# Web Push (VAPID) is optional: the in-app notification bell always works;
# these enable real OS-level push notifications too. Generate a keypair with
# `make vapid-keys` (or `npx web-push generate-vapid-keys`), then set both
# keys below.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost
